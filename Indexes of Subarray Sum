import java.util.ArrayList;
class Solution {
    static ArrayList<Integer> subarraySum(int[] arr, int target) {
        // code here
        ArrayList<Integer> result = new ArrayList<>();
        int start=0;
        int sum =0;
        for(int i =0;i<arr.length;i++){
            sum =sum+arr[i];
            while(sum > target && start <= i){
                sum =sum-arr[start];
                start++;
            }
            if(sum == target){
                result.add(start+1);
                result.add(i+1);
                return result;
            }
        }
        result.add(-1);
        return result;
    }
}
